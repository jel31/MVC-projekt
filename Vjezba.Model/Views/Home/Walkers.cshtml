@model IReadOnlyList<Vjezba.Model.DogWalker>

@{
    ViewData["Title"] = "Šetači";
}

<section class="page-header" aria-labelledby="walkers-title">
    <div>
        <span class="eyebrow">Naš tim</span>
        <h1 id="walkers-title">Šetači</h1>
        <p class="page-subtitle">Usporedite cijenu, ocjenu i lokaciju na jednom mjestu.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-outline" href="@Url.Action("Bookings", "Home")">Pogledaj rezervacije</a>
        <a class="btn btn-outline" href="@Url.Action("Index", "Home")">Natrag na početnu</a>
    </div>
</section>

@if (!Model.Any())
{
    <section class="empty-state" aria-live="polite">
        <h2>Još nema šetača</h2>
        <p>Dodajte profile šetača kako bi ih vlasnici mogli početi rezervirati.</p>
        <a class="btn btn-primary" href="@Url.Action("Index", "Home")">Vrati se na početnu</a>
    </section>
}
else
{
    <section class="entity-grid" aria-label="Popis šetača">
        @foreach (var walker in Model)
        {
            <article class="entity-card">
                <div class="entity-card__title">
                    <div>
                        <h2>@walker.Name @walker.Surname</h2>
                    </div>
                </div>

                <div class="entity-tags">
                    <span class="entity-tag">€@walker.HourlyRate.ToString("F2") / h</span>
                    <span class="entity-tag">⭐ Ocjena @walker.AverageRating.ToString("F1")</span>
                    <span class="entity-tag">Lokacija: @walker.Address</span>
                </div>

                <div class="entity-card__actions">
                    <a class="btn btn-primary" href="@Url.Action("Walker", "Home", new { id = walker.Id })">Detalji</a>
                </div>
            </article>
        }
    </section>
}
